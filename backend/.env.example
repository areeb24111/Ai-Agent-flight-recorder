DATABASE_URL=sqlite:///./agent_recorder.db
OPENAI_API_KEY=

# Optional: if set, POST /api/v1/runs and POST /api/v1/simulations require
# header X-API-Key or Authorization: Bearer <value>
API_KEY=

# Rate limits per client IP per minute (0 = unlimited)
RATE_LIMIT_INGEST_PER_MINUTE=120
RATE_LIMIT_SIMULATIONS_PER_MINUTE=30

# Production: comma-separated CORS origins (e.g. https://myapp.fly.dev)
# CORS_ORIGINS=

# Production: serve frontend from this dir for single-host deploy (e.g. ./static)
# STATIC_DIR=

# Optional: POST to this URL when a run has failure score >= WEBHOOK_THRESHOLD (0-100)
# WEBHOOK_URL=
# WEBHOOK_THRESHOLD=80

# Optional: only persist a Failure when score >= threshold (0-100). Unset = persist all.
# DETECTOR_HALLUCINATION_THRESHOLD=80
# DETECTOR_PLANNING_FAILURE_THRESHOLD=80
# DETECTOR_TOOL_MISUSE_THRESHOLD=70
# DETECTOR_REASONING_LOOP_THRESHOLD=70
# DETECTOR_MEMORY_CONTRADICTION_THRESHOLD=60
